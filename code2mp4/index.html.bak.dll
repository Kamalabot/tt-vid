<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1080, height=1920" />
    <title>Professional DLL Visualizer</title>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.2/dist/gsap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.2/dist/TextPlugin.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Outfit:wght@300;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #050508;
            --node-border: rgba(0, 229, 255, 0.3);
            --node-bg: rgba(10, 15, 25, 0.9);
            --accent: #00e5ff;
            --link-color: #7c4dff;
            --text: #e0e0e6;
            --kw: #ff79c6;
            --fn: #50fa7b;
            --str: #f1fa8c;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { width: 1080px; height: 1920px; background: var(--bg); color: var(--text); font-family: 'Outfit', sans-serif; overflow: hidden; }

        #root { width: 1080px; height: 1920px; position: relative; }

        .header { position: absolute; top: 80px; width: 100%; text-align: center; font-size: 64px; font-weight: 800; letter-spacing: -2px; }

        /* Node Container */
        .node-container {
            position: absolute;
            left: 50%; transform: translateX(-50%);
            display: flex; flex-direction: column; gap: 150px;
            top: 300px;
        }

        .node-wrapper { position: relative; opacity: 0; transform: translateY(50px); }

        .addr-label {
            position: absolute; top: -45px; left: 20px;
            font-family: 'JetBrains Mono'; font-size: 24px; color: var(--accent);
            background: rgba(0, 229, 255, 0.1); padding: 4px 12px; border-radius: 8px;
        }

        .node {
            width: 700px; height: 140px;
            background: var(--node-bg); border: 2px solid var(--node-border);
            border-radius: 20px; display: flex; backdrop-filter: blur(20px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }

        .part { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; border-right: 1px solid rgba(255,255,255,0.1); }
        .part:last-child { border-right: none; }
        .p-label { font-size: 18px; color: rgba(255,255,255,0.3); margin-bottom: 5px; font-weight: 600; }
        .p-val { font-family: 'JetBrains Mono'; font-size: 32px; font-weight: 700; }
        .data-val { color: var(--accent); font-size: 48px; }

        /* Connections */
        #svg-layer { position: absolute; top: 0; left: 0; width: 1080px; height: 1920px; pointer-events: none; z-index: 5; }
        .link { fill: none; stroke: var(--link-color); stroke-width: 5; stroke-dasharray: 2000; stroke-dashoffset: 2000; opacity: 0.8; }
        .arrowhead { fill: var(--link-color); }

        /* Code Block */
        .code-box {
            position: absolute; bottom: 120px; left: 50%; transform: translateX(-50%);
            width: 900px; background: #0a0a0f; border-radius: 30px;
            padding: 50px; border: 1px solid rgba(255,255,255,0.05);
            font-family: 'JetBrains Mono', monospace; font-size: 26px; line-height: 1.5;
            box-shadow: 0 -20px 60px rgba(0,0,0,0.5);
        }

        .line { opacity: 0.3; }
        .line.active { opacity: 1; background: rgba(124, 77, 255, 0.15); border-left: 4px solid var(--link-color); padding-left: 10px; }

        .narration { position: absolute; top: 180px; width: 100%; text-align: center; font-size: 36px; font-weight: 300; color: #888; }
        
        .clip { }
    </style>
</head>
<body>
    <div id="root" data-composition-id="code2mp4" data-start="0" data-duration="30" data-width="1080" data-height="1920">
        
        <div class="header clip" data-start="0" data-duration="30" data-track-index="0">Doubly Linked List</div>
        <div id="narrator" class="narration clip" data-start="0" data-duration="30" data-track-index="1">System Booting...</div>

        <!-- Connections Layer -->
        <svg id="svg-layer" class="clip" data-start="0" data-duration="30" data-track-index="2" viewBox="0 0 1080 1920">
            <defs>
                <marker id="arr" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto">
                    <path d="M0,0 L8,4 L0,8 Z" class="arrowhead" />
                </marker>
            </defs>
            <!-- Node 1 Next -> Node 2 -->
            <path id="l1next" class="link" d="M 740 440 Q 850 440 850 515 T 740 590" marker-end="url(#arr)" />
            <!-- Node 2 Prev -> Node 1 -->
            <path id="l2prev" class="link" d="M 340 590 Q 230 590 230 515 T 340 440" marker-end="url(#arr)" />
            
            <!-- Node 2 Next -> Node 3 -->
            <path id="l2next" class="link" d="M 740 730 Q 850 730 850 805 T 740 880" marker-end="url(#arr)" />
            <!-- Node 3 Prev -> Node 2 -->
            <path id="l3prev" class="link" d="M 340 880 Q 230 880 230 805 T 340 730" marker-end="url(#arr)" />
        </svg>

        <div class="node-container">
            <!-- Node 1 (Head) -->
            <div id="w1" class="node-wrapper clip" data-start="0" data-duration="30" data-track-index="10">
                <div class="addr-label">0x100</div>
                <div class="node">
                    <div class="part"><span class="p-label">PREV</span><span class="p-val" id="n1-p">NULL</span></div>
                    <div class="part"><span class="p-label">DATA</span><span class="p-val data-val">10</span></div>
                    <div class="part"><span class="p-label">NEXT</span><span class="p-val" id="n1-n">NULL</span></div>
                </div>
            </div>

            <!-- Node 2 -->
            <div id="w2" class="node-wrapper clip" data-start="0" data-duration="30" data-track-index="11">
                <div class="addr-label">0x200</div>
                <div class="node">
                    <div class="part"><span class="p-label">PREV</span><span class="p-val" id="n2-p">NULL</span></div>
                    <div class="part"><span class="p-label">DATA</span><span class="p-val data-val">20</span></div>
                    <div class="part"><span class="p-label">NEXT</span><span class="p-val" id="n2-n">NULL</span></div>
                </div>
            </div>

            <!-- Node 3 -->
            <div id="w3" class="node-wrapper clip" data-start="0" data-duration="30" data-track-index="12">
                <div class="addr-label">0x300</div>
                <div class="node">
                    <div class="part"><span class="p-label">PREV</span><span class="p-val" id="n3-p">NULL</span></div>
                    <div class="part"><span class="p-label">DATA</span><span class="p-val data-val">30</span></div>
                    <div class="part"><span class="p-label">NEXT</span><span class="p-val" id="n3-n">NULL</span></div>
                </div>
            </div>
        </div>

        <!-- Professional Code Editor -->
        <div class="code-box clip" data-start="0" data-duration="30" data-track-index="20">
            <div class="line" id="cl1"><span class="kw">class</span> <span class="fn">Node</span>:</div>
            <div class="line" id="cl2">&nbsp;&nbsp;&nbsp;&nbsp;<span class="kw">def</span> <span class="fn">__init__</span>(self, data):</div>
            <div class="line" id="cl3">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;self.data = data</div>
            <div class="line" id="cl4">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;self.next = <span class="kw">None</span></div>
            <div class="line" id="cl5">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;self.prev = <span class="kw">None</span></div>
            <div class="line" id="cl6" style="margin-top: 15px;"><span class="kw">def</span> <span class="fn">append</span>(head, data):</div>
            <div class="line" id="cl7">&nbsp;&nbsp;&nbsp;&nbsp;new_node = <span class="fn">Node</span>(data)</div>
            <div class="line" id="cl8">&nbsp;&nbsp;&nbsp;&nbsp;current.next = new_node</div>
            <div class="line" id="cl9">&nbsp;&nbsp;&nbsp;&nbsp;new_node.prev = current</div>
        </div>
    </div>

    <script>
        gsap.registerPlugin(TextPlugin);

        window.__timelines = window.__timelines || {};
        const tl = gsap.timeline({ paused: true });

        // Phase 1: Setup (0-5s)
        tl.to("#narrator", { text: "Creating Doubly Linked List...", duration: 1.5 }, 1);
        tl.to("#cl1", { className: "line active", duration: 0.5 }, 1.5);
        
        // Node 1
        tl.to("#w1", { opacity: 1, y: 0, duration: 1, ease: "power3.out" }, 2.5);
        tl.to("#narrator", { text: "Head Node created at 0x100", duration: 1.5 }, 3);

        // Phase 2: Insert Node 2 (5-15s)
        tl.to("#narrator", { text: "Appending Data: 20", duration: 1.5 }, 6);
        tl.to("#cl7", { className: "line active", duration: 0.3 }, 6.5);
        tl.to("#w2", { opacity: 1, y: 0, duration: 1, ease: "power3.out" }, 7.5);
        
        // Link 1 -> 2
        tl.to("#cl8", { className: "line active", duration: 0.3 }, 9);
        tl.to("#l1next", { strokeDashoffset: 0, duration: 1.5, ease: "power1.inOut" }, 9.5);
        tl.to("#n1-n", { text: "0x200", duration: 0.5, color: "#00e5ff" }, 10.5);
        
        // Link 2 -> 1
        tl.to("#cl9", { className: "line active", duration: 0.3 }, 12);
        tl.to("#l2prev", { strokeDashoffset: 0, duration: 1.5, ease: "power1.inOut" }, 12.5);
        tl.to("#n2-p", { text: "0x100", duration: 0.5, color: "#00e5ff" }, 13.5);
        tl.to(["#cl8", "#cl9"], { className: "line", duration: 0.3 }, 14.5);

        // Phase 3: Insert Node 3 (15-25s)
        tl.to("#narrator", { text: "Appending Data: 30 at 0x300", duration: 1.5 }, 16);
        tl.to("#w3", { opacity: 1, y: 0, duration: 1, ease: "power3.out" }, 17);
        
        // Link 2 -> 3
        tl.to("#l2next", { strokeDashoffset: 0, duration: 1.5, ease: "power1.inOut" }, 19);
        tl.to("#n2-n", { text: "0x300", duration: 0.5, color: "#00e5ff" }, 20);
        
        // Link 3 -> 2
        tl.to("#l3prev", { strokeDashoffset: 0, duration: 1.5, ease: "power1.inOut" }, 22);
        tl.to("#n3-p", { text: "0x200", duration: 0.5, color: "#00e5ff" }, 23);

        // Phase 4: Final Traversal (25-30s)
        tl.to("#narrator", { text: "Traversal logic: Head -> Next -> Next", duration: 2, color: "#fff" }, 25);
        tl.to("#w1", { scale: 1.05, borderColor: "#fff", duration: 0.5 }, 26);
        tl.to("#w1", { scale: 1, borderColor: "rgba(0, 229, 255, 0.3)", duration: 0.5 }, 27);
        tl.to("#w2", { scale: 1.05, borderColor: "#fff", duration: 0.5 }, 27.5);
        tl.to("#w2", { scale: 1, borderColor: "rgba(0, 229, 255, 0.3)", duration: 0.5 }, 28.5);
        tl.to("#w3", { scale: 1.1, backgroundColor: "rgba(0, 229, 255, 0.15)", duration: 0.5 }, 29);
        tl.to("#narrator", { text: "Data Found: 30", duration: 1 }, 29);

        window.__timelines["code2mp4"] = tl;
    </script>
</body>
</html>
