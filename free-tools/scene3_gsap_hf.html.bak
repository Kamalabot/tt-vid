<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Democratizing Design - LLMs</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <style>
        :root {
            --bg: #f5f5f7;
            --text: #1d1d1f;
            --accent: #0071e3;
            --glass: rgba(255, 255, 255, 0.75);
            --border: rgba(0, 0, 0, 0.1);
            --shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: var(--bg);
            color: var(--text);
            overflow: hidden;
            width: 1080px;
            height: 1920px;
        }

        #canvas {
            position: relative;
            width: 100%;
            height: 100%;
            background: #fff;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .clip {
            position: absolute;
            opacity: 0;
            visibility: hidden;
        }

        /* Split Screen */
        .comparison-container {
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .side {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
            padding: 60px;
            overflow: hidden;
        }

        .side-traditional { background: #f2f2f2; }
        .side-llm { background: #fff; }

        .icon-box {
            width: 260px;
            height: 260px;
            background: #fff;
            border-radius: 70px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: var(--shadow);
            margin-bottom: 40px;
            font-size: 110px;
        }

        .label {
            font-size: 36px;
            font-weight: 700;
            color: #86868b;
            text-transform: uppercase;
            letter-spacing: 4px;
        }

        .time-badge {
            margin-top: 25px;
            font-size: 72px;
            font-weight: 900;
            color: var(--text);
        }

        /* Combined Scene Styles */
        .main-stage {
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;
            padding: 150px 60px;
            background: #fff;
        }

        .prompt-box {
            width: 100%;
            max-width: 960px;
            background: var(--glass);
            border: 2px solid var(--border);
            border-radius: 50px;
            padding: 60px;
            backdrop-filter: blur(40px);
            box-shadow: var(--shadow);
        }

        .prompt-text {
            font-size: 52px;
            font-weight: 600;
            color: #1d1d1f;
            border-bottom: 5px solid var(--accent);
            padding-bottom: 25px;
            margin-top: 20px;
        }

        .layers-wrapper {
            margin-top: 50px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .layer-item {
            height: 90px;
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 24px;
            display: flex;
            align-items: center;
            padding: 0 40px;
            font-size: 32px;
            font-weight: 600;
            color: #86868b;
        }

        /* Centered Hero Text */
        .centered-hero {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 100%;
            text-align: center;
            z-index: 200;
        }

        .democratize-title {
            font-size: 130px;
            font-weight: 900;
            line-height: 0.9;
            letter-spacing: -6px;
            text-transform: uppercase;
        }

        .accent { color: var(--accent); }

        /* Footer Logos */
        .hf-footer {
            position: absolute;
            bottom: 100px;
            width: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 40px;
            z-index: 10;
        }

    </style>
</head>
<body>
    <div id="canvas" data-composition-id="main" data-width="1080" data-height="1920" data-start="0" data-duration="10">
        
        <!-- SCENE 1: Comparison -->
        <div id="scene-1" class="clip comparison-container" data-start="0" data-duration="4" data-track-index="1">
            <div id="top-traditional" class="side side-traditional">
                <div class="label">Traditional Effort</div>
                <div id="clock-icon" class="icon-box">⏳</div>
                <div class="time-badge">6+ HOURS</div>
            </div>
            <div id="bottom-llm" class="side side-llm">
                <div class="label">LLM Speed</div>
                <div id="flash-icon" class="icon-box">⚡</div>
                <div class="time-badge">SECONDS</div>
            </div>
        </div>

        <!-- SCENE 2: The Synthesis (Combined) -->
        <div id="scene-2" class="clip main-stage" data-start="4" data-duration="6" data-track-index="1">
            
            <!-- Prompt Box (Top) -->
            <div id="prompt-container" class="prompt-box">
                <div class="label">Simple Prompt</div>
                <div class="prompt-text">"Create premium motion graphics..."</div>
                <div id="layers" class="layers-wrapper">
                    <div class="layer-item">Configure GSAP Timelines</div>
                    <div class="layer-item">Build Dynamic Components</div>
                    <div class="layer-item">Optimize for Hyperframes</div>
                </div>
            </div>

            <!-- Centered Hero Text -->
            <div id="hero-text" class="centered-hero" style="opacity: 0;">
                <div class="democratize-title">
                    DEMOCRATIZING<br><span class="accent">DESIGN</span>
                </div>
            </div>

            <!-- Footer Logos -->
            <div id="hf-logo" class="hf-footer" style="opacity: 0;">
                <!-- Hyperframes Logo -->
                <div style="color: var(--accent);">
                    <svg width="280" height="90" viewBox="0 0 263 79" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0 16.6738H4.96V23.3838H11.53V16.6738H16.49V35.4538H11.53V27.6738H4.96V35.4538H0V16.6738Z" fill="currentColor"/>
