                </svg>
            </div>

        </div>

    </div>

    <script>
        window.__timelines = window.__timelines || {};
        const tl = gsap.timeline({ paused: true });
        window.__timelines["main"] = tl;

        // Visibility Logic
        const clips = document.querySelectorAll('.clip');
        clips.forEach(clip => {
            const start = parseFloat(clip.dataset.start);
            const duration = parseFloat(clip.dataset.duration);
            tl.set(clip, { autoAlpha: 1, visibility: 'visible' }, start);
            tl.set(clip, { autoAlpha: 0, visibility: 'hidden' }, start + duration);
        });

        // --- SCENE 1: Comparison ---
        tl.from("#top-traditional", { y: -960, duration: 1.2, ease: "power4.out" }, 0);
        tl.from("#bottom-llm", { y: 960, duration: 1.2, ease: "power4.out" }, 0);
        
        tl.to("#clock-icon", { rotation: 360, repeat: 1, duration: 2, ease: "none" }, 0);
        tl.from("#flash-icon", { scale: 0.5, autoAlpha: 0, duration: 0.8, ease: "back.out(1.7)" }, 0.5);

        // Transition Scene 1 -> 2
        tl.to("#top-traditional", { height: 0, duration: 0.8, ease: "power3.inOut" }, 3.5);
        tl.to("#bottom-llm", { height: 1920, duration: 0.8, ease: "power3.inOut" }, 3.5);

        // --- SCENE 2: The Synthesis ---
        tl.from("#prompt-container", { y: -100, autoAlpha: 0, duration: 0.8, ease: "power3.out" }, 4.0);
        
        // Typewriter Effect for Prompt (Fills 4s - 6s)
        const promptText = '"Create premium motion graphics..."';
        const promptEl = document.querySelector('.prompt-text');
        
        tl.set(promptEl, { textContent: "" }, 4.0);
        tl.to({}, {
            duration: 2.0,
            onUpdate: function() {
                const charCount = Math.floor(this.ratio * promptText.length);
                promptEl.innerText = promptText.substring(0, charCount);
            }
        }, 4.2);

        tl.from(".layer-item", { x: 50, autoAlpha: 0, stagger: 0.1, duration: 0.5, ease: "power3.out" }, 5.8);
        
        // Flattening layers & Push Up
        tl.to(".layer-item", { 
            y: (i) => -110 * i, 
            autoAlpha: 0, 
            stagger: 0.05, 
            duration: 0.4, 
            ease: "power3.in" 
        }, 6.5);
        
        tl.to("#prompt-container", { scale: 0.85, y: -80, duration: 0.8, ease: "power2.inOut" }, 6.5);

        // Centered Hero Reveal
        tl.to("#hero-text", { autoAlpha: 1, duration: 0.8, ease: "expo.out" }, 7.2);
        tl.from("#hero-text .democratize-title", { y: 60, scale: 0.9, duration: 1, ease: "expo.out" }, 7.2);
        
        // Logo Reveal at bottom
        tl.to("#hf-logo", { autoAlpha: 1, y: -20, duration: 0.8, ease: "back.out(1.5)" }, 8.5);

    </script>
</body>
</html>
